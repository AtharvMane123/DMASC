<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0E0E0E"
    android:fitsSystemWindows="true"
    tools:context=".CameraActivity">

    <!-- Dark Layer Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#121212" />

    <!-- Main Content with AppBar and Camera -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
>
        <!-- Modern Toolbar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="#1E1E1E"
            android:background="@drawable/bg_toolbar"
            android:elevation="8dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_alignParentStart="true">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/logo_image"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:src="@drawable/logo"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/RoundedCornerImage"
                        android:backgroundTint="#282828" />

                    <TextView
                        android:id="@+id/app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="DMASC Innovations"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/settings"
                    android:contentDescription="Settings"
                    android:tint="#FFFFFF"
                    android:padding="8dp"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </androidx.appcompat.widget.Toolbar>


        <!-- Camera View Container -->
        <FrameLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerInParent="true"
            android:layout_alignParentRight="true"
            android:layout_margin="16dp"
            android:background="@drawable/rounded_camera_preview"
            android:elevation="4dp"
            tools:context=".CameraActivity" />

    </RelativeLayout>

    <!-- Bottom Sheet Include (Expanded by Default) -->
    <include
        android:id="@+id/bottom_sheet_layout"
        android:visibility="gone"
        layout="@layout/tfe_od_layout_bottom_sheet" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
