<resources>

    <!-- Updated base theme for Material -->
    <style name="AppTheme.ObjectDetection" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">@color/tfe_color_primary</item>
        <item name="colorPrimaryDark">@color/tfe_color_primary_dark</item>
        <item name="colorAccent">@color/tfe_color_accent</item>

        <!-- Optional: Customize status bar, nav bar, etc. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="RoundedCornerImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    <style name="RoundedCornerImage_Home">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20%</item>
    </style>

</resources>
